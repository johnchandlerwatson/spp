      "pluginVersion": "11.0.0",
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 22, "w": 24, "x": 0, "y": 2 },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{job=\"spp-app\", http_method=~\"$method\", http_status=~\"$status\", http_path=~\"$path\"} | json | level=~\"$log_level\" | duration_ms > $min_duration",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Stream",
      "type": "logs"
    }
  ],
